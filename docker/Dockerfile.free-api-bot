FROM node:22-alpine AS deps
WORKDIR /app
COPY package.json ./
COPY shared/package.json shared/package.json
COPY backend/package.json backend/package.json
COPY discord-bot/package.json discord-bot/package.json
COPY frontend/package.json frontend/package.json
RUN npm install --workspaces --include-workspace-root

FROM deps AS build
COPY tsconfig.base.json ./
COPY shared shared
COPY backend backend
COPY discord-bot discord-bot
RUN npm run build --workspace @cod-amp/shared
RUN npm run build --workspace @cod-amp/backend
RUN npm run build --workspace @cod-amp/discord-bot

FROM node:22-alpine AS runner
WORKDIR /app
ENV NODE_ENV=production
COPY --from=deps /app/node_modules ./node_modules
COPY --from=build /app/shared/dist ./shared/dist
COPY --from=build /app/shared/package.json ./shared/package.json
COPY --from=build /app/backend/dist ./backend/dist
COPY --from=build /app/backend/public ./backend/public
COPY --from=build /app/backend/package.json ./backend/package.json
COPY --from=build /app/discord-bot/dist ./discord-bot/dist
COPY --from=build /app/discord-bot/package.json ./discord-bot/package.json
COPY docker/start-free-api-bot.mjs ./docker/start-free-api-bot.mjs
CMD ["node", "docker/start-free-api-bot.mjs"]
